prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: gpiodglib
Description: GObject bindings for libgpiod
URL: @PACKAGE_URL@
Version: @PACKAGE_VERSION@
Requires.private: libgpiod >= 2.1
Libs: -L${libdir} -lgpiodglib
Cflags: -I${includedir}
